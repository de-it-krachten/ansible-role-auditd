---

# Generic
generic:
  role: ansible-role-auditd
  role_short: auditd
  role_description: |
    Installs/configures auditd
  collections: []

# Supported platforms
platforms:
  sles15:
    supported: true
    ci: false
  sles16:
    supported: true
    ci: false
  opensuse15:
    supported: true
    ci: true
  opensuse16:
    supported: true
    ci: true
  ubuntu2004:
    supported: true
    ci: true

# Molecule
molecule:
  requirements:
    roles_extra: []

